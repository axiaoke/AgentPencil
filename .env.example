# ============================================
# 博客系统环境变量配置示例
# 复制本文件为 .env 并填写实际值
# ============================================

# 服务端口
PORT=8086

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=blog

# JWT 密钥
JWT_SECRET=your_jwt_secret_key_here_change_it

# 阿里云百炼 API
BAILIAN_API_KEY=your_bailian_api_key_here
BAILIAN_GENERATE_APP_ID=your_generate_app_id_here
BAILIAN_AUDIT_APP_ID=your_audit_app_id_here

# WordPress 迁移（仅迁移时使用）
WP_DB_HOST=localhost
WP_DB_PORT=3306
WP_DB_USER=root
WP_DB_PASSWORD=your_wp_password_here
WP_DB_NAME=wordpress
WP_TABLE_PREFIX=wp_

# 站点 URL（用于生成完整链接）
SITE_URL=http://localhost:8086

# API 发布、编辑文章配置说明（.env）
AGENT_WRITE_TOKEN=your_write_token_here
AGENT_DEFAULT_AUTHOR=axiaoke        # 可选，默认已是 axiaoke
AGENT_DEFAULT_CATEGORY=技术文档     # 可选，默认已是技术文档